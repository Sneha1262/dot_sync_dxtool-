# Copy this file to .env and fill in your values.
# Never commit your real .env to git.

# Path to your SSH private key on the host machine
# Windows: C:/Users/YOUR_USERNAME/.ssh/dx_sync_key
# Linux/macOS: /home/YOUR_USERNAME/.ssh/dx_sync_key
SSH_KEY_PATH=C:/Users/YOUR_USERNAME/.ssh/dx_sync_key

# SSH URL for your dots repo — no token, no expiry
DOTS_REPO_URL=git@github.com:YOUR_USERNAME/dots-repo.git

# Where the repo is cloned inside the container
DOTS_DIR=/root/dots

# How often (seconds) each container pulls from remote
SYNC_INTERVAL=15

# all = sync every file in the repo
# dotfiles_only = only sync files whose name starts with a dot
SYNC_MODE=all
